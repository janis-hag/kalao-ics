T4INC	= $(THOME)/include

INCLUDE_PATH =	-I .					
		#\
		#-I $(INC_DIR) 				\
		#-I $(T4INC) 				\
		#-I $(OPENWINHOME)/include		\
        	#-I /usr/include/x86_64-linux-gnu/       \
        	#-I /usr/local/include

INC_DIR		= ../libgop/		

CDEBUGFLAGS += -g

CFLAGS	+= $(CDEBUGFLAGS) -fPIC -Wall -DUSE_STRERROR -DSYSV -DLINUX -I . -I ../libgop/
#-DLINUX $(INCLUDE_PATH)

ARFLAGS += -U

RANLIB	= echo


