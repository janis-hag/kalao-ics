[Unit]
Description=KalAO safety timer service

[Service]
Type=simple
ExecStart=/home/kalao/kalao-ics/scripts/kalao_safety-timer.sh
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=MILK_SHM_DIR=/tmp/milk

[Install]
WantedBy=default.target
