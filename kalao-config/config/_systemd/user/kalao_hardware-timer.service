[Unit]
Description=KalAO - Hardware timer
After=kalao_system-setup.service
After=mongodb.service

[Service]
Type=simple
ExecStart=/home/kalao/kalao-ics/scripts/kalao_hardware-timer.sh
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=MILK_SHM_DIR=/tmp/milk

[Install]
WantedBy=default.target
