[Unit]
Description=KalAO - GUI Backend

After=network-online.target
Wants=network-online.target

After=kalao_system-setup.service
After=mongod.service
After=redis-server.service

[Service]
Type=simple
ExecStart=/home/kalao/kalao-ics/scripts/kalao_gui-backend.sh
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=MILK_SHM_DIR=/tmp/milk

[Install]
WantedBy=default.target
