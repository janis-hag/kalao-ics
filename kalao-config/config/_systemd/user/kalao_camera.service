
[Unit]
Description=KalAO Camera control service

[Service]
Type=simple
ExecStart=/home/kalao/kalao-fli/launch-KalAOCamera.sh
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=MILK_SHM_DIR=/tmp/milk

[Install]
WantedBy=default.target
#WantedBy=multi-user.target
